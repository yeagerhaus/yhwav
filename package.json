{
	"name": "yhplayer",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "tsx ./tools/run.ts ",
		"web": "expo start --web",
		"test": "jest --watchAll",
		"prep": "bun install && npx pod-install",
		"kill": "lsof -ti:8081 | xargs kill -9",
		"clean": "rm -rf node_moduels && rm -rf ios/Pods ios/Podfile.lock && rm -rf .expo",
		"up": "bun update; bunx expo@latest install --check",
		"b": "eas build --profile development --platform ios",
		"check:tsc": "tsc --project tsconfig.json --noEmit",
		"check:biome": "biome check --formatter-enabled=true --linter-enabled=true --vcs-enabled=true --write --unsafe .",
		"check:eslint": "eslint ./",
		"check:all": "bun check:tsc && bun check:biome && bun check:eslint"
	},
	"jest": {
		"preset": "jest-expo"
	},
	"dependencies": {
		"@expo/metro-runtime": "~6.1.2",
		"@expo/vector-icons": "^15.0.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-native-community/slider": "5.0.1",
		"@react-native-masked-view/masked-view": "0.3.2",
		"@react-navigation/bottom-tabs": "^7.4.0",
		"@react-navigation/native": "^7.1.8",
		"dotenv": "^17.2.2",
		"expo": "^54.0.10",
		"expo-blur": "~15.0.7",
		"expo-constants": "~18.0.9",
		"expo-dev-client": "~6.0.12",
		"expo-device": "~8.0.8",
		"expo-document-picker": "~14.0.7",
		"expo-file-system": "~19.0.15",
		"expo-font": "~14.0.8",
		"expo-haptics": "~15.0.7",
		"expo-linear-gradient": "~15.0.7",
		"expo-linking": "~8.0.8",
		"expo-router": "~6.0.8",
		"expo-splash-screen": "~31.0.10",
		"expo-status-bar": "~3.0.8",
		"expo-symbols": "~1.0.7",
		"expo-system-ui": "~6.0.7",
		"expo-web-browser": "~15.0.7",
		"fast-xml-parser": "^5.2.5",
		"jose": "^6.1.0",
		"lodash": "^4.17.21",
		"music-metadata-browser": "^2.5.11",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.4",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-get-music-files": "^2.2.4",
		"react-native-image-colors": "^2.5.0",
		"react-native-reanimated": "~4.1.2",
		"react-native-safe-area-context": "~5.6.1",
		"react-native-screens": "~4.16.0",
		"react-native-skeleton-placeholder": "^5.2.4",
		"react-native-track-player": "^4.1.2",
		"react-native-web": "^0.21.1",
		"react-native-webview": "13.15.0",
		"react-native-worklets": "0.5.1",
		"tsx": "^4.20.5",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@babel/core": "^7.28.4",
		"@biomejs/biome": "2.0.0",
		"@types/jest": "^29.5.14",
		"@types/lodash": "^4.17.20",
		"@types/react": "~19.1.13",
		"@types/react-test-renderer": "^18.3.1",
		"jest": "^29.7.0",
		"jest-expo": "~54.0.12",
		"react-test-renderer": "18.3.1",
		"typescript": "~5.9.2"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"exclude": ["react-native-track-player", "react-native-get-music-files"]
			}
		}
	},
	"private": true
}
