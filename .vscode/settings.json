{
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/build": true
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit",
		"source.organizeImports.biome": "explicit",
    	"source.fixAll.biome": "explicit"
	},
	"javascript.validate.enable": false,
	"editor.formatOnPaste": false,
	"editor.formatOnType": false,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	/* 
		Used to identify the VS Code window by color (for when multiple windows are open) 
		Feel free to change colors if you want, but please don't remove it altogether
	*/
	"peacock.remoteColor": "#3E3EBC",
	"workbench.colorCustomizations": {
		"activityBar.activeBackground": "#6262F5",
		"activityBar.background": "#4E4EDE",
		"activityBar.foreground": "#FFFFFF",
		"activityBar.inactiveForeground": "#FFFFFF99",
		"activityBarBadge.background": "#2E2E96",
		"activityBarBadge.foreground": "#FFFFFF",
		"commandCenter.border": "#FFFFFF99",
		"sash.hoverBorder": "#6262F5",
		"statusBar.background": "#3E3EBC",
		"statusBar.foreground": "#FFFFFF",
		"statusBarItem.hoverBackground": "#6262F5",
		"statusBarItem.remoteBackground": "#3E3EBC",
		"statusBarItem.remoteForeground": "#FFFFFF",
		"titleBar.activeBackground": "#3E3EBC",
		"titleBar.activeForeground": "#FFFFFF",
		"titleBar.inactiveBackground": "#3E3EBC99",
		"titleBar.inactiveForeground": "#FFFFFF99"
	}
}
