{
	"name": "yhplayer",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "tsx ./tools/run.ts ",
		"web": "expo start --web",
		"prep": "bun install && npx pod-install",
		"kill": "lsof -ti:8081 | xargs kill -9",
		"clean": "rm -rf node_moduels && rm -rf ios/Pods ios/Podfile.lock && rm -rf .expo",
		"up": "bun update; bunx expo@latest install --check",
		"b": "eas build --profile development --platform ios",
		"check:tsc": "tsc --project tsconfig.json --noEmit",
		"check:biome": "biome check --formatter-enabled=true --linter-enabled=true --vcs-enabled=true --write --unsafe .",
		"check:all": "bun check:tsc && bun check:biome"
	},
	"dependencies": {
		"@expo/metro-runtime": "~6.1.2",
		"@expo/vector-icons": "^15.0.3",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"@react-native-community/slider": "5.0.1",
		"@react-navigation/bottom-tabs": "^7.9.0",
		"@react-navigation/native": "^7.1.26",
		"dotenv": "^17.2.3",
		"expo": "^54.0.29",
		"expo-blur": "~15.0.8",
		"expo-constants": "~18.0.12",
		"expo-crypto": "^15.0.8",
		"expo-dev-client": "~6.0.20",
		"expo-device": "~8.0.10",
		"expo-file-system": "~19.0.21",
		"expo-glass-effect": "~0.1.8",
		"expo-haptics": "~15.0.8",
		"expo-linear-gradient": "~15.0.8",
		"expo-linking": "~8.0.10",
		"expo-router": "~6.0.20",
		"expo-splash-screen": "~31.0.12",
		"expo-status-bar": "~3.0.9",
		"expo-symbols": "^1.0.8",
		"expo-system-ui": "~6.0.9",
		"expo-web-browser": "~15.0.10",
		"lodash": "^4.17.21",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-get-random-values": "^1.11.0",
		"react-native-image-colors": "^2.5.1",
		"react-native-reanimated": "~4.1.6",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.16.0",
		"react-native-skeleton-placeholder": "^5.2.4",
		"react-native-track-player": "^4.1.2",
		"react-native-web": "^0.21.2",
		"tsx": "^4.21.0",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@biomejs/biome": "2.0.0",
		"@types/lodash": "^4.17.21",
		"@types/react": "~19.1.17",
		"typescript": "~5.9.3"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"exclude": [
					"react-native-track-player"
				]
			}
		}
	},
	"private": true
}
