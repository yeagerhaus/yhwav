{
  "name": "yhplayer",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "tsx ./tools/run.ts ",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "i": "bun install && npx pod-install && npx expo prebuild --platform ios",
    "up": "bun update; bunx expo@latest install --check",
    "b": "eas build --profile development --platform ios",
    "check:tsc": "tsc --project tsconfig.json --noEmit",
    "check:biome": "biome check --formatter-enabled=true --linter-enabled=true --vcs-enabled=true --write --unsafe .",
    "check:eslint": "eslint ./",
    "check:all": "bun check:tsc && bun check:biome && bun check:eslint"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/bottom-tabs": "^7.3.15",
    "@react-navigation/native": "^7.1.11",
    "expo": "^53.0.11",
    "expo-av": "~15.1.6",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.6",
    "expo-dev-client": "^5.2.1",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^13.1.5",
    "expo-file-system": "^18.1.10",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.1.0",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.8",
    "expo-web-browser": "~14.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.3",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-get-music-files": "^2.2.4",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-track-player": "^4.1.1",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5",
    "tsx": "^4.20.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@biomejs/biome": "2.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^18.3.1",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.7",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.8.3"
  },
  "private": true
}
