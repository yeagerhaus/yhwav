# Plex Media Server Configuration
EXPO_PUBLIC_PLEX_SERVER=https://your-plex-server.com
EXPO_PUBLIC_PLEX_TOKEN=your-plex-token
EXPO_PUBLIC_PLEX_MUSIC_SECTION_ID=your-music-section-id

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Plex server details
# 3. The app will automatically generate unique client IDs per device
# 4. JWT authentication is handled automatically - no additional setup needed!
