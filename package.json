{
	"name": "yhplayer",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "tsx ./tools/run.ts ",
		"web": "expo start --web",
		"test": "jest --watchAll",
		"prep": "bun install && npx pod-install",
		"kill": "lsof -ti:8081 | xargs kill -9",
		"clean": "rm -rf node_moduels && rm -rf ios/Pods ios/Podfile.lock && rm -rf .expo",
		"up": "bun update; bunx expo@latest install --check",
		"b": "eas build --profile development --platform ios",
		"check:tsc": "tsc --project tsconfig.json --noEmit",
		"check:biome": "biome check --formatter-enabled=true --linter-enabled=true --vcs-enabled=true --write --unsafe .",
		"check:eslint": "eslint ./",
		"check:all": "bun check:tsc && bun check:biome && bun check:eslint"
	},
	"jest": {
		"preset": "jest-expo"
	},
	"dependencies": {
		"@expo/vector-icons": "^14.1.0",
		"@react-native-async-storage/async-storage": "2.1.2",
		"@react-native-community/slider": "4.5.6",
		"@react-navigation/bottom-tabs": "^7.4.7",
		"@react-navigation/native": "^7.1.17",
		"dotenv": "^17.2.2",
		"expo": "^53.0.22",
		"expo-blur": "~14.1.5",
		"expo-constants": "~17.1.7",
		"expo-dev-client": "^5.2.4",
		"expo-device": "~7.1.4",
		"expo-document-picker": "^13.1.6",
		"expo-file-system": "^18.1.11",
		"expo-font": "~13.3.2",
		"expo-haptics": "~14.1.4",
		"expo-linear-gradient": "~14.1.5",
		"expo-linking": "~7.1.7",
		"expo-router": "~5.1.5",
		"expo-splash-screen": "~0.30.10",
		"expo-status-bar": "~2.2.3",
		"expo-symbols": "~0.4.5",
		"expo-system-ui": "~5.0.11",
		"expo-web-browser": "~14.2.0",
		"fast-xml-parser": "^5.2.5",
		"lodash": "^4.17.21",
		"music-metadata-browser": "^2.5.11",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"react-native": "0.79.5",
		"react-native-gesture-handler": "~2.24.0",
		"react-native-get-music-files": "^2.2.4",
		"react-native-image-colors": "^2.5.0",
		"react-native-reanimated": "~3.17.5",
		"react-native-safe-area-context": "5.4.0",
		"react-native-screens": "~4.11.1",
		"react-native-skeleton-placeholder": "^5.2.4",
		"react-native-track-player": "^4.1.2",
		"react-native-web": "^0.20.0",
		"react-native-webview": "13.13.5",
		"tsx": "^4.20.5",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@babel/core": "^7.28.3",
		"@biomejs/biome": "2.0.0",
		"@types/jest": "^29.5.14",
		"@types/lodash": "^4.17.20",
		"@types/react": "~19.0.14",
		"@types/react-test-renderer": "^18.3.1",
		"jest": "^29.7.0",
		"jest-expo": "~53.0.10",
		"react-test-renderer": "18.3.1",
		"typescript": "~5.8.3"
	},
	"private": true
}
