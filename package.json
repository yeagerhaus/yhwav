{
	"name": "yhwav",
	"main": "expo-router/entry",
	"version": "0.1",
	"scripts": {
		"start": "tsx ./tools/run.ts ",
		"web": "expo start --web",
		"prep": "bun install && npx pod-install",
		"kill": "lsof -ti:8081 | xargs kill -9",
		"clean": "rm -rf node_modules && rm -rf ios/Pods ios/Podfile.lock && rm -rf .expo",
		"up": "bun update; bunx expo@latest install --check",
		"b": "eas build --profile development --platform ios",
		"b:test": "npx expo run:ios --configuration Release --device",
		"check:tsc": "tsc --project tsconfig.json --noEmit",
		"check:biome": "biome check --formatter-enabled=true --linter-enabled=true --vcs-enabled=true --write --unsafe .",
		"check:all": "bun check:tsc && bun check:biome",
		"prepare": "husky",
		"android": "expo run:android",
		"ios": "expo run:ios"
	},
	"dependencies": {
		"@expo/metro-runtime": "~6.1.2",
		"@react-native-community/slider": "5.0.1",
		"@react-navigation/native": "7.1.28",
		"@shopify/flash-list": "2.0.2",
		"dotenv": "^17.3.1",
		"expo": "^54.0.33",
		"expo-background-fetch": "^14.0.9",
		"expo-blur": "~15.0.8",
		"expo-constants": "~18.0.13",
		"expo-crypto": "^15.0.8",
		"expo-dev-client": "~6.0.20",
		"expo-device": "~8.0.10",
		"expo-file-system": "~19.0.21",
		"expo-glass-effect": "~0.1.9",
		"expo-haptics": "~15.0.8",
		"expo-image": "~3.0.11",
		"expo-linear-gradient": "~15.0.8",
		"expo-linking": "~8.0.11",
		"expo-notifications": "^0.32.16",
		"expo-router": "~6.0.23",
		"expo-splash-screen": "~31.0.13",
		"expo-status-bar": "~3.0.9",
		"expo-symbols": "^1.0.8",
		"expo-system-ui": "~6.0.9",
		"expo-task-manager": "^14.0.9",
		"expo-web-browser": "~15.0.10",
		"fast-xml-parser": "^5.3.7",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-draggable-flatlist": "^4.0.3",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-get-random-values": "^1.11.0",
		"react-native-image-colors": "^2.5.1",
		"react-native-mmkv": "^4.3.0",
		"react-native-reanimated": "~4.1.6",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.16.0",
		"react-native-web": "^0.21.2",
		"tsx": "^4.21.0",
		"yhwav-audio": "file:./modules/yhwav-audio",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "2.0.0",
		"@types/react": "~19.1.17",
		"baseline-browser-mapping": "^2.10.0",
		"husky": "^9.1.7",
		"typescript": "~5.9.3"
	},
	"overrides": {
		"baseline-browser-mapping": "^2.9.19"
	},
	"expo": {},
	"private": true
}
